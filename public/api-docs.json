{
    "projectName": "本地接口文档系统",
    "description": "用于前后端联调的轻量级接口文档查看器",
    "groups": [
        {
            "name": "用户认证",
            "apis": [
                {
                    "title": "用户登录",
                    "method": "POST",
                    "path": "/api/user/login",
                    "description": "使用用户名和密码登录，登录成功后返回 token。前端需要把 token 存入本地，并在后续请求中放入 Authorization 请求头。",
                    "headers": [
                        {
                            "name": "Content-Type",
                            "type": "string",
                            "required": true,
                            "default": "application/json",
                            "description": "请求体类型"
                        }
                    ],
                    "body": [
                        {
                            "name": "username",
                            "type": "string",
                            "required": true,
                            "description": "用户名"
                        },
                        {
                            "name": "password",
                            "type": "string",
                            "required": true,
                            "description": "密码"
                        }
                    ],
                    "example": {
                        "username": "admin",
                        "password": "123456"
                    },
                    "response": {
                        "code": 200,
                        "message": "success",
                        "data": {
                            "token": "mock-token-value"
                        }
                    }
                },
                {
                    "title": "获取用户信息",
                    "method": "GET",
                    "path": "/api/user/info",
                    "description": "根据 Authorization token 获取当前登录用户信息。",
                    "headers": [
                        {
                            "name": "Authorization",
                            "type": "string",
                            "required": true,
                            "default": "Bearer {{token}}",
                            "description": "登录后获取的 token"
                        }
                    ],
                    "query": [],
                    "example": {},
                    "response": {
                        "code": 200,
                        "message": "success",
                        "data": {
                            "id": 1,
                            "username": "admin",
                            "role": "admin"
                        }
                    }
                }
            ]
        },
        {
            "name": "文章管理",
            "apis": [
                {
                    "title": "获取文章列表",
                    "method": "GET",
                    "path": "/api/articles",
                    "description": "分页获取文章列表。",
                    "headers": [
                        {
                            "name": "Authorization",
                            "type": "string",
                            "required": true,
                            "default": "Bearer {{token}}",
                            "description": "登录 token"
                        }
                    ],
                    "query": [
                        {
                            "name": "page",
                            "type": "number",
                            "required": false,
                            "description": "页码"
                        },
                        {
                            "name": "pageSize",
                            "type": "number",
                            "required": false,
                            "description": "每页数量"
                        }
                    ],
                    "example": {
                        "page": 1,
                        "pageSize": 10
                    },
                    "response": {
                        "code": 200,
                        "message": "success",
                        "data": {
                            "list": [],
                            "total": 0
                        }
                    }
                },
                {
                    "title": "创建文章",
                    "method": "POST",
                    "path": "/api/articles",
                    "description": "创建一篇新的文章。",
                    "headers": [
                        {
                            "name": "Authorization",
                            "type": "string",
                            "required": true,
                            "default": "Bearer {{token}}",
                            "description": "登录 token"
                        },
                        {
                            "name": "Content-Type",
                            "type": "string",
                            "required": true,
                            "default": "application/json",
                            "description": "请求体类型"
                        }
                    ],
                    "body": [
                        {
                            "name": "title",
                            "type": "string",
                            "required": true,
                            "description": "文章标题"
                        },
                        {
                            "name": "content",
                            "type": "string",
                            "required": true,
                            "description": "文章内容"
                        }
                    ],
                    "example": {
                        "title": "第一篇文章",
                        "content": "文章正文内容"
                    },
                    "response": {
                        "code": 200,
                        "message": "created",
                        "data": {
                            "id": 1
                        }
                    }
                },
                {
                    "title": "删除文章",
                    "method": "DELETE",
                    "path": "/api/articles/{id}",
                    "description": "根据文章 ID 删除文章。",
                    "headers": [
                        {
                            "name": "Authorization",
                            "type": "string",
                            "required": true,
                            "default": "Bearer {{token}}",
                            "description": "登录 token"
                        }
                    ],
                    "params": [
                        {
                            "name": "id",
                            "type": "number",
                            "required": true,
                            "description": "文章 ID"
                        }
                    ],
                    "example": {
                        "id": 1
                    },
                    "response": {
                        "code": 200,
                        "message": "deleted",
                        "data": true
                    }
                }
            ]
        }
    ]
}